{
  "name": "icsc-conf-github-io",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm run build:css && pnpm run build:pages",
    "build:css": "tailwindcss -i ./src/styles/site.css -o ./site.css --minify",
    "build:pages": "tsx scripts/build-pages.tsx",
    "build:root": "pnpm run build:pages"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.18.1",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@tailwindcss/cli": "^4.1.12",
    "tailwindcss": "^4.1.12",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
